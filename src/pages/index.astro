---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Header from '../components/Header.astro';
import BusinessCard from '../components/BusinessCard.astro';
import ProjectList from '../components/ProjectList.astro';
import CallToAction from '../components/CallToAction.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Revan Fatkhurezi | Digital Solutions Specialist & Founder RevTech"
  description="Portofolio resmi Revan Fatkhurezi. Temukan berbagai proyek inovasi teknologi, AI, dan layanan pengembangan aplikasi web inovatif melalui RevTech."
>
  <ThemeToggle />
  
  <main class="max-w-3xl md:max-w-4xl lg:max-w-5xl mx-auto px-5 sm:px-8 md:px-12 w-full flex flex-col gap-10 md:gap-14 relative z-10">
    <Header />
    <BusinessCard />
    <ProjectList />
    <CallToAction />
  </main>
  
  <Footer />
</Layout>
