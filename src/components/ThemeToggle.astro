---
import { Icon } from 'astro-icon/components';
---

<button 
  id="theme-toggle"
  class="fixed top-6 right-6 z-50 p-3 rounded-full glass-button shadow-sm text-on-surface dark:text-dark-on-surface group"
  aria-label="Toggle Dark Mode"
  onclick="window.toggleTheme()"
>
  <div class="relative w-5 h-5 flex items-center justify-center">
    <Icon name="feather:sun" class="absolute inset-0 w-full h-full text-amber-500 transition-all duration-500 transform scale-0 rotate-90 dark:scale-100 dark:rotate-0" id="icon-sun" />
    <Icon name="feather:moon" class="absolute inset-0 w-full h-full text-indigo-500 transition-all duration-500 transform scale-100 rotate-0 dark:scale-0 dark:-rotate-90" id="icon-moon" />
  </div>
</button>
