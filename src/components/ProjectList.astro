---
import { Icon } from 'astro-icon/components';
---

<section class="flex flex-col gap-4 w-full animate-fade-in-up delay-200">
  <div class="flex flex-col gap-1 text-center">
    <h4 class="text-xs md:text-sm font-semibold text-outline dark:text-dark-on-surface-variant uppercase tracking-wider">
      EKSPLORASI & INOVASI
    </h4>
    <p class="text-sm md:text-base lg:text-lg text-on-surface-variant dark:text-dark-on-surface-variant max-w-xl mx-auto">
      Kumpulan proyek independen dan eksperimen teknologi personal saya.
    </p>
  </div>

  <div class="mt-2 w-full flex flex-col gap-4">
    <a 
      href="#"
      target="_blank"
      rel="noopener noreferrer"
      class="block glass-panel rounded-2xl p-6 group flex flex-col gap-4 hover:border-primary/50 transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02] hover:shadow-lg dark:hover:shadow-primary/5"
    >
      <div class="flex items-center justify-between w-full">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl bg-surface-bright dark:bg-dark-bg border border-border-subtle dark:border-dark-border flex items-center justify-center text-primary flex-shrink-0 transition-colors duration-300 group-hover:bg-primary/10 group-hover:border-primary/20 overflow-hidden">
            <img src="/images/revai-logo.png" alt="RevAI Logo" class="w-full h-full object-cover" />
          </div>
          <h3 class="text-lg md:text-xl lg:text-2xl font-semibold text-on-surface dark:text-dark-on-surface flex flex-wrap items-center gap-2 md:gap-3">
            JudulAI
            <span class="text-[10px] md:text-xs font-bold bg-amber-500/10 dark:bg-amber-500/20 text-amber-600 dark:text-amber-400 px-2 md:px-2.5 py-0.5 md:py-1 rounded-full uppercase tracking-wider flex-shrink-0 mt-0.5 md:mt-0">
              Segera Hadir
            </span>
          </h3>
        </div>
        <div class="text-outline dark:text-dark-on-surface-variant group-hover:text-primary dark:group-hover:text-primary transition-all duration-300 flex-shrink-0 group-hover:translate-x-1">
          <Icon name="feather:arrow-right" class="w-5 h-5" />
        </div>
      </div>
      <p class="text-sm md:text-base lg:text-lg text-on-surface-variant dark:text-dark-on-surface-variant leading-relaxed mt-2 md:mt-3 w-full pl-0 md:pl-20 text-left">
        AI assistant untuk membantu menemukan ide judul Akademik kamu!
      </p>
    </a>

    <a 
      href="#"
      target="_blank"
      rel="noopener noreferrer"
      class="block glass-panel rounded-2xl p-6 group flex flex-col gap-4 hover:border-primary/50 transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02] hover:shadow-lg dark:hover:shadow-primary/5"
    >
      <div class="flex items-center justify-between w-full">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl bg-surface-bright dark:bg-dark-bg border border-border-subtle dark:border-dark-border flex items-center justify-center text-primary flex-shrink-0 transition-colors duration-300 group-hover:bg-primary/10 group-hover:border-primary/20 overflow-hidden">
            <img src="/images/validata-ai-logo.png" alt="Validata AI Logo" class="w-full h-full object-contain scale-110" />
          </div>
          <h3 class="text-lg md:text-xl lg:text-2xl font-semibold text-on-surface dark:text-dark-on-surface flex flex-wrap items-center gap-2 md:gap-3">
            Validata AI
          </h3>
        </div>
        <div class="text-outline dark:text-dark-on-surface-variant group-hover:text-primary dark:group-hover:text-primary transition-all duration-300 flex-shrink-0 group-hover:translate-x-1">
          <Icon name="feather:arrow-right" class="w-5 h-5" />
        </div>
      </div>
      <p class="text-sm md:text-base lg:text-lg text-on-surface-variant dark:text-dark-on-surface-variant leading-relaxed mt-2 md:mt-3 w-full pl-0 md:pl-20 text-left">
        Sistem validasi dokumen nasabah berbasis AI sebagai solusi digitalisasi administrasi untuk Laporan Magang di Bank BRI KCP Sukanagara.
      </p>
    </a>
  </div>
</section>
