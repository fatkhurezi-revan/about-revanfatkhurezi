---
import { Icon } from 'astro-icon/components';
import profilePic from '../../public/images/profile-pic.png';
---

<header class="flex flex-col items-center text-center gap-6 animate-fade-in-up">
  <div class="relative group cursor-pointer">
    <div class="absolute -inset-2 bg-primary rounded-full blur-xl opacity-40 animate-pulse group-hover:opacity-100 transition-opacity duration-500"></div>
    <div class="relative w-32 h-32 md:w-40 md:h-40 rounded-full border-4 border-surface-white dark:border-dark-bg overflow-hidden shadow-xl transform transition-all duration-500 group-hover:scale-110 group-hover:rotate-3">
      <img 
        src="/images/profile-pic.png" 
        alt="Revan Fatkhurezi" 
        class="w-full h-full object-cover"
      />
    </div>
  </div>
  
  <div class="flex flex-col items-center gap-2">
    <div class="flex items-center gap-2 bg-primary/10 dark:bg-primary/20 text-primary dark:text-blue-300 px-4 py-1.5 rounded-full text-xs font-bold tracking-wider mb-2">
      <Icon name="feather:code" class="w-3.5 h-3.5" />
      <span>DIGITAL SOLUTIONS SPECIALIST</span>
    </div>
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-on-surface dark:text-dark-on-surface">
      Revan Fatkhurezi
    </h1>
    <h2 class="text-lg md:text-xl lg:text-2xl text-on-surface-variant dark:text-dark-on-surface-variant max-w-lg md:max-w-2xl mt-2 leading-relaxed">
      Founder of <span class="text-primary font-semibold">RevTech</span>
    </h2>
  </div>
  
  <div class="flex gap-4 mt-2">
    <a href="https://github.com/fatkhurezi-revan" target="_blank" rel="noopener noreferrer" class="p-3 rounded-full bg-surface-bright dark:bg-dark-bg/50 border border-border-subtle dark:border-dark-border text-on-surface-variant dark:text-dark-on-surface-variant hover:text-primary dark:hover:text-primary hover:border-primary/50 transition-all duration-300 shadow-sm hover:shadow-lg hover:-translate-y-1 hover:scale-110">
      <Icon name="feather:github" class="w-5 h-5" />
    </a>
    <a href="#" onclick="event.preventDefault();" class="p-3 rounded-full bg-surface-bright dark:bg-dark-bg/50 border border-border-subtle dark:border-dark-border text-on-surface-variant/50 dark:text-dark-on-surface-variant/50 cursor-not-allowed transition-all duration-300 shadow-sm" title="Belum Tersedia">
      <Icon name="feather:linkedin" class="w-5 h-5" />
    </a>
    <a href="https://www.instagram.com/revanfatkhurezi_" target="_blank" rel="noopener noreferrer" class="p-3 rounded-full bg-surface-bright dark:bg-dark-bg/50 border border-border-subtle dark:border-dark-border text-on-surface-variant dark:text-dark-on-surface-variant hover:text-pink-500 dark:hover:text-pink-400 hover:border-pink-500/50 transition-all duration-300 shadow-sm hover:shadow-lg hover:-translate-y-1 hover:scale-110">
      <Icon name="feather:instagram" class="w-5 h-5" />
    </a>
    <a href="https://mail.google.com/mail/?view=cm&fs=1&to=revanfatkhureziii@gmail.com" target="_blank" rel="noopener noreferrer" class="p-3 rounded-full bg-surface-bright dark:bg-dark-bg/50 border border-border-subtle dark:border-dark-border text-on-surface-variant dark:text-dark-on-surface-variant hover:text-primary dark:hover:text-primary hover:border-primary/50 transition-all duration-300 shadow-sm hover:shadow-lg hover:-translate-y-1 hover:scale-110">
      <Icon name="feather:mail" class="w-5 h-5" />
    </a>
  </div>
</header>
